# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files — ignore real envs, but keep the committed template
.env*
!.env.example

# local sqlite database (contains password hash + prod data)
/data
*.db
*.db-wal
# encryption key for channel secrets at rest — never commit
.secret_key
*.db-shm

# internal-only / operator-local scripts + ad-hoc docs (never commit)
/scripts/docker-push.sh
/scripts/create_endpoint_change_doc.py
*.docx

# playwright e2e
/test-results
/playwright-report
/blob-report
/playwright/.cache
/e2e/.auth

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
