# SQLite database file. Accepts a bare path or file: URI. Directory auto-created.
DATABASE_URL="./data/apm.db"

# 32+ char random string for signing session JWTs (openssl rand -hex 32)
SESSION_SECRET=""

# Optional: protects /api/cron/tick. Set on Vercel Cron header.
CRON_SECRET=""

# Optional: key for encrypting channel secrets (Telegram token, Resend key) at
# rest in the DB. Any string; if unset, a random key is generated once and
# persisted to <data-dir>/.secret_key. Do NOT reuse SESSION_SECRET.
ENCRYPTION_KEY=""

# Optional: if set, /api/metrics (Prometheus) requires Authorization: Bearer <token>
METRICS_TOKEN=""

# Base URL for links in notification templates
APP_BASE_URL="http://localhost:3000"
